<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tencent.wxcloudrun.dao.CardMapper">


    <update id="changeStatus">
        update card set status = 1 where id = #{name} where status = 0
    </update>
    <select id="getAll" resultType="com.tencent.wxcloudrun.model.Card">
        select * from card
    </select>
    <select id="select" resultType="com.tencent.wxcloudrun.model.Card">
        select * from card where id = #{id}
    </select>
</mapper>